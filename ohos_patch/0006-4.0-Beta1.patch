+  elif sort_by == 'time':
+    file_infos.sort(key=lambda info: info[1])
+  elif sort_by == 'name':
+    file_infos.sort(key=lambda info: info[2])
+  else:
+    raise ValueError("Wrong sort_by value: %s" % sort_by)
+
