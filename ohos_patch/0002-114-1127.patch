+  if (strategy_) {
+    std::unique_ptr<base::Value> out;
+    LOG(DEBUG) << "FromV8Object is_function = " << is_function
+               << ", is_promise = " << is_promise;
+    if (strategy_->FromV8Object(val, &out, isolate, is_function, is_promise))
+      return out;
