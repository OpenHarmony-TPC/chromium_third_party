+    FromV8ValueState* state,
+    v8::Isolate* isolate,
+    bool is_function,
+    bool is_promise) const {
+  ScopedUniquenessGuard uniqueness_guard(state, val);
+  if (!uniqueness_guard.is_valid())
+    return std::make_unique<base::Value>();
