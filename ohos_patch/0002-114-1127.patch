+                      /*viewport_point=*/gfx::Point(),
+                      /*is_wheel_scroll=*/false,
+                      /*affect_browser_controls=*/false,
+                      /*scroll_outer_viewport=*/true);
+  client_->SetNeedsCommitOnImplThread();
+  client_->RenewTreePriority();
+}
+#endif
